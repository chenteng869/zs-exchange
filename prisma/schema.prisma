  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @db.Timestamptz

  @@unique([roleId, permissionId, scope, scopeValue])
  @@index([roleId])
  @@index([permissionId])
  @@index([status])
  @@index([expiresAt])
  @@map("fjn_role_permissions")
}

// 18.4 用户-角色映射
model FjnUserRole {
