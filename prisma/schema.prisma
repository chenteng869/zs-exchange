  id                      String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                  String     @db.Uuid
  accountType             String     @db.VarChar(32)
  asset                   String     @db.VarChar(32)
  balance                 Decimal    @default(0) @db.Decimal(36, 18)
