  leverage                Int        @default(1)
  marginMode              String     @db.VarChar(16)
  isolatedMargin          Decimal    @default(0) @db.Decimal(36, 18)
  crossMarginUsed         Decimal    @default(0) @db.Decimal(36, 18)
  positionMargin          Decimal    @default(0) @db.Decimal(36, 18)
  unrealizedPnl           Decimal    @default(0) @db.Decimal(36, 18)
  realizedPnl             Decimal    @default(0) @db.Decimal(36, 18)
