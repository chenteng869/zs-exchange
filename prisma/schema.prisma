// ============================================================
// 19. Region 域（三级地区 + 限制 + IP Geo）
// ============================================================

// 19.1 Region 树（country / province / city / district）
model FjnRegion {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  regionCode      String    @unique @db.VarChar(64)
  regionName      String    @db.VarChar(128)
  level           String    @db.VarChar(16) // country | province | city | district
  parentId        String?   @db.Uuid
  countryCode     String    @db.Char(2) // ISO 3166-1 alpha-2
  subdivisionCode String?   @db.VarChar(8) // ISO 3166-2（CN-35 / US-CA）
  locale          String?   @db.VarChar(8) // zh-CN / en-US
  timezone        String?   @db.VarChar(64)
  latitude        Decimal?  @db.Decimal(10, 6)
  longitude       Decimal?  @db.Decimal(10, 6)
  status          String    @default("active") @db.VarChar(16) // active | disabled | deprecated
  isSystem        Boolean   @default(false)
  sort            Int       @default(0)
  metadata        Json?     @db.JsonB
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt       DateTime? @db.Timestamptz

  parent       FjnRegion?             @relation("FjnRegionTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     FjnRegion[]            @relation("FjnRegionTree")
  restrictions FjnRegionRestriction[]
  ipGeos       FjnIpGeoRange[]

  @@index([level])
  @@index([parentId])
  @@index([countryCode])
  @@index([status])
  @@index([countryCode, level])
  @@map("fjn_regions")
}

// 19.2 Region 限制（限售 / KYC 升级 / 风控 / 合规 / 白名单）
model FjnRegionRestriction {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  regionId          String    @db.Uuid
  restrictionType   String    @db.VarChar(32) // block_trade | kyc_upgrade | risk_high | compliance_report | allowlist
  restrictionSource String    @default("internal") @db.VarChar(16) // regulator | internal | partner | risk_engine | sanctions
  reason            String?   @db.Text
  refNo             String?   @db.VarChar(64) // 关联的合规文号 / 制裁清单号
  status            String    @default("active") @db.VarChar(16) // active | disabled | expired
  validFrom         DateTime? @db.Timestamptz
  expiresAt         DateTime? @db.Timestamptz
  metadata          Json?     @db.JsonB
  createdBy         String?   @db.Uuid
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @db.Timestamptz

  region FjnRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, restrictionType])
  @@index([restrictionType])
  @@index([status])
  @@index([expiresAt])
  @@index([regionId, status])
  @@map("fjn_region_restrictions")
}

// 19.3 IP 段→地区映射（IP Geo）
model FjnIpGeoRange {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ipVersion      String    @default("ipv4") @db.VarChar(8) // ipv4 | ipv6
  ipRangeStart   String    @db.VarChar(64) // 文本起始（含 CIDR 起始 IP）
  ipRangeEnd     String    @db.VarChar(64) // 文本结束
  ipStartNum     BigInt // 数值起始（用于区间查询）
  ipEndNum       BigInt // 数值结束
  regionId       String    @db.Uuid
  countryCode    String    @db.Char(2)
  provinceCode   String?   @db.VarChar(8)
  cityCode       String?   @db.VarChar(64)
  isp            String?   @db.VarChar(64)
  connectionType String?   @db.VarChar(16) // isp | datacenter | mobile | corporate | residential
  status         String    @default("active") @db.VarChar(16) // active | disabled
  source         String    @default("internal") @db.VarChar(16) // internal | ip_geo_provider | manual
  confidence     Int       @default(100) // 0-100
  metadata       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt      DateTime? @db.Timestamptz

  region FjnRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@index([ipVersion])
  @@index([ipStartNum, ipEndNum])
  @@index([regionId])
  @@index([countryCode])
  @@index([status])
  @@map("fjn_ip_geo_ranges")
}

// ============================================================
// 20. Device 域（用户 ↔ 设备 + 黑名单 + 风险 + Challenge）
// ============================================================

// 20.1 UserDevice 绑定（user ↔ device 1:N）
model FjnUserDevice {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String    @db.Uuid
  fingerprintId    String    @db.Uuid
  deviceName       String?   @db.VarChar(100)
  deviceType       String?   @db.VarChar(16) // desktop | mobile | tablet | tv | iot | server | unknown
  status           String    @default("pending") @db.VarChar(16) // pending | active | trusted | blocked | revoked
  isPrimary        Boolean   @default(false) // 用户主设备标记
  boundAt          DateTime  @default(now()) @db.Timestamptz
  lastActiveAt     DateTime  @default(now()) @db.Timestamptz
  boundIpAddress   String?   @db.VarChar(64)
  boundCountryCode String?   @db.Char(2)
  lastIpAddress    String?   @db.VarChar(64)
  lastCountryCode  String?   @db.Char(2)
  lastCityCode     String?   @db.VarChar(64)
  riskScore        Int       @default(0) // 0-100
  riskLevel        String    @default("low") @db.VarChar(16) // low | medium | high | critical
  visitCount       Int       @default(1)
  sessionCount     Int       @default(0)
  notes            String?   @db.Text
  metadata         Json?     @db.JsonB
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt        DateTime? @db.Timestamptz

  fingerprint     FjnDeviceFingerprint      @relation("FingerprintToUserDevices", fields: [fingerprintId], references: [id], onDelete: Cascade)
  trustLogs       FjnDeviceTrustLog[]
  riskAssessments FjnDeviceRiskAssessment[]
  challenges      FjnDeviceChallenge[]

  @@unique([userId, fingerprintId])
  @@index([userId])
  @@index([fingerprintId])
  @@index([status])
  @@index([riskLevel])
  @@index([userId, status])
  @@index([lastActiveAt])
  // K-6: "我的设备"页面：用户设备按最近活跃排序
  @@index([userId, lastActiveAt])
  // K-6: 设备指纹反向查询：哪些用户在使用此指纹
  @@index([fingerprintId, status])
  @@map("fjn_user_devices")
}

// 20.2 TrustLog（设备信任状态变更历史）
model FjnDeviceTrustLog {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userDeviceId String   @db.Uuid
  trustAction  String   @db.VarChar(16) // trust | untrust | revoke | block | unblock
  fromStatus   String?  @db.VarChar(16)
  toStatus     String?  @db.VarChar(16)
  reason       String?  @db.Text
  riskScore    Int? // 评分快照
  operatorId   String?  @db.Uuid
  operatorType String   @default("admin") @db.VarChar(16) // admin | user | system | risk_engine
  metadata     Json?    @db.JsonB
  createdAt    DateTime @default(now()) @db.Timestamptz

  userDevice FjnUserDevice @relation(fields: [userDeviceId], references: [id], onDelete: Cascade)

  @@index([userDeviceId])
  @@index([trustAction])
  @@index([createdAt])
  @@map("fjn_device_trust_logs")
}

// 20.3 Blacklist（设备黑名单）
model FjnDeviceBlacklist {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fingerprint     String    @unique @db.VarChar(255)
  fingerprintHash String?   @db.VarChar(128) // K-6: SHA-256 哈希索引（快速比对）
  reason          String    @db.VarChar(32) // fraud | abuse | stolen_device | terrorist_financing | sanctions | aml_violation | internal
  blacklistSource String    @default("internal") @db.VarChar(16) // admin | risk_engine | regulator | partner | internal
  refNo           String?   @db.VarChar(64) // 关联的合规文号 / 制裁清单号
  description     String?   @db.Text
  status          String    @default("active") @db.VarChar(16) // active | disabled | expired
  addedBy         String?   @db.Uuid
  validFrom       DateTime? @db.Timestamptz
  expiresAt       DateTime? @db.Timestamptz
  metadata        Json?     @db.JsonB
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @db.Timestamptz

  @@index([fingerprintHash])
  @@index([reason])
  @@index([blacklistSource])
  @@index([status])
  // K-6: 高频查询：active + 有效期过滤
  @@index([status, expiresAt])
  // K-6: 来源 + 状态聚合分析
  @@index([blacklistSource, status])
  @@map("fjn_device_blacklists")
}

// 20.4 RiskAssessment（设备风险评估历史）
model FjnDeviceRiskAssessment {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userDeviceId String?  @db.Uuid
  userId       String?  @db.Uuid
  fingerprint  String   @db.VarChar(255)
  riskScore    Int // 0-100
  riskLevel    String   @db.VarChar(16) // low | medium | high | critical
  factors      String[] // 命中的风险因子
  action       String   @default("none") @db.VarChar(16) // none | challenge | block | trust
  status       String   @default("scored") @db.VarChar(16) // scored | dismissed | actioned
  kycLevel     String?  @db.VarChar(16) // 评分时的 KYC 等级
  ipAddress    String?  @db.VarChar(64)
  countryCode  String?  @db.Char(2)
  notes        String?  @db.Text
  metadata     Json?    @db.JsonB
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamptz

  userDevice FjnUserDevice? @relation(fields: [userDeviceId], references: [id], onDelete: SetNull)

  @@index([userDeviceId])
  @@index([userId])
  @@index([fingerprint])
  @@index([riskLevel])
  @@index([status])
  @@index([createdAt])
  // K-6: 用户风险历史时间序列查询
  @@index([userId, createdAt])
  // K-6: 风险仪表盘：按风险等级 + 时间窗口
  @@index([riskLevel, createdAt])
  @@map("fjn_device_risk_assessments")
}

// 20.5 Challenge（新设备验证挑战）
model FjnDeviceChallenge {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userDeviceId  String    @db.Uuid
  userId        String    @db.Uuid
  challengeType String    @db.VarChar(32) // otp_email | otp_sms | otp_totp | biometric_face | biometric_finger | security_question | admin_approval
  trigger       String    @db.VarChar(32) // new_device | suspicious_location | high_risk_score | password_reset | sensitive_operation | admin_forced
  target        String    @db.VarChar(255) // 邮箱/手机号（脱敏）
  codeHash      String?   @db.VarChar(255) // 验证码哈希（不存明文）
  status        String    @default("pending") @db.VarChar(16) // pending | verified | failed | expired | cancelled
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  ipAddress     String?   @db.VarChar(64)
  userAgent     String?   @db.VarChar(512)
  verifiedAt    DateTime? @db.Timestamptz
  expiresAt     DateTime  @db.Timestamptz
  metadata      Json?     @db.JsonB
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @db.Timestamptz

  userDevice FjnUserDevice @relation(fields: [userDeviceId], references: [id], onDelete: Cascade)

  @@index([userDeviceId])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, status])
  // K-6: 清理过期挑战 + 状态过滤
  @@index([status, expiresAt])
  @@map("fjn_device_challenges")
}

// ============================================================
// 21. MFA 域（多因素认证 - TOTP + 备份码）
// ============================================================

// 21.1 UserMfa 绑定（每用户 1 条 MFA 记录）
model FjnUserMfa {
  id     String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId String @unique @db.Uuid
  status String @default("pending") @db.VarChar(16) // pending | active | disabled | locked

  // TOTP Secret（base32 编码）
  secret       String? @db.VarChar(255) // 激活后保存的真实 secret
  enrollSecret String? @db.VarChar(255) // enroll 阶段临时 secret

  // 备份码（10 个 SHA-256 哈希）
  backupCodes String[] @db.Text // 数组存储哈希值

  // 时间戳
  activatedAt     DateTime? @db.Timestamptz
  disabledAt      DateTime? @db.Timestamptz
  lastUsedAt      DateTime? @db.Timestamptz
  lastUsedCounter BigInt? // TOTP 计数器（防重放）

  // 失败控制（5 次失败锁定 15 分钟）
  failedAttempts Int       @default(0)
  lockedUntil    DateTime? @db.Timestamptz

  // 业务标识
  method            String  @default("totp") @db.VarChar(16) // totp | sms | email | backup_code
  deviceFingerprint String? @db.VarChar(255) // 启用 MFA 时所用设备

  metadata  Json?     @db.JsonB
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  // 关系
  auditLogs FjnUserMfaAuditLog[]

  @@index([userId])
  @@index([status])
  @@index([lockedUntil])
  // K-6: 高频查询：查找锁定中 + 状态过滤
  @@index([status, lockedUntil])
  @@map("fjn_user_mfa")
}

// 21.2 UserMfaAuditLog（MFA 操作审计日志）
model FjnUserMfaAuditLog {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @db.Uuid
  userMfaId String?  @db.Uuid
  action    String   @db.VarChar(32) // enroll | activate | verify_success | verify_fail | disable | regenerate_backup | lock | unlock
  method    String?  @db.VarChar(16) // totp | backup_code
  ipAddress String?  @db.VarChar(64)
  userAgent String?  @db.VarChar(512)
  success   Boolean  @default(true)
  reason    String?  @db.VarChar(255)
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @db.Timestamptz

  userMfa FjnUserMfa? @relation(fields: [userMfaId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userMfaId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
  // K-6: 失败检测：按 action + success + 时间过滤（M-3 告警统计用）
  @@index([action, success, createdAt])
  @@index([userId, action, createdAt])
  @@map("fjn_user_mfa_audit_logs")
}

// 21.3 MfaPolicy (L-2: 管理员强制 MFA 策略)
model FjnMfaPolicy {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // 策略范围：单用户 / 角色 / 全局
  scope    String  @db.VarChar(16) // user | role | global
  userId   String? @db.Uuid
  roleName String? @db.VarChar(32)
  kycLevel String? @db.VarChar(16) // 触发条件：达到此 KYC 等级强制

  // 策略内容
  required        Boolean  @default(true) // 是否强制启用 MFA
  gracePeriodDays Int      @default(7) // 宽限期天数
  exemptRoles     String[] @db.Text // 豁免角色数组

  // 审计
  enabledBy     String? @db.Uuid
  enabledByType String  @default("admin") @db.VarChar(16) // admin | system
  reason        String? @db.VarChar(255)
  metadata      Json?   @db.JsonB

  enabledAt  DateTime  @default(now()) @db.Timestamptz
  disabledAt DateTime? @db.Timestamptz
  expiresAt  DateTime? @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz

  @@index([scope])
  @@index([userId])
  @@index([roleName])
  @@index([kycLevel])
  @@index([enabledAt])
  @@index([scope, userId])
  @@index([scope, roleName])
  @@map("fjn_mfa_policies")
}

// 21.4 MfaEnforcementLog (L-2: 强制 MFA 触发日志)
model FjnMfaEnforcementLog {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @db.Uuid
  policyId  String?  @db.Uuid
  trigger   String   @db.VarChar(32) // kyc_upgrade | admin_enroll | login | sensitive_op
  action    String   @db.VarChar(16) // prompted | enrolled | skipped | blocked | exempted
  reason    String?  @db.VarChar(255)
  ipAddress String?  @db.VarChar(64)
  userAgent String?  @db.VarChar(512)
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([userId])
  @@index([policyId])
  @@index([trigger])
  @@index([action])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("fjn_mfa_enforcement_logs")
}

// 21.5 WebAuthnCredential (L-3: WebAuthn / FIDO2 凭证)
model FjnWebAuthnCredential {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String    @db.Uuid
  credentialId   String    @unique @db.VarChar(512) // base64url 编码
  publicKey      String    @db.Text // base64 编码 COSE 公钥
  counter        BigInt    @default(0) // 防重放计数器
  credentialType String    @default("public-key") @db.VarChar(32)
  transports     String[]  @db.Text // usb | nfc | ble | internal | hybrid
  aaguid         String?   @db.VarChar(64) // 认证器 GUID
  fmt            String?   @db.VarChar(32) // attestation format
  deviceName     String?   @db.VarChar(100)
  deviceType     String?   @db.VarChar(16) // single_device | multi_device
  backupEligible Boolean   @default(false)
  backupState    Boolean   @default(false)
  userVerified   Boolean   @default(false)
  lastUsedAt     DateTime? @db.Timestamptz
  registeredAt   DateTime  @default(now()) @db.Timestamptz
  revokedAt      DateTime? @db.Timestamptz
  metadata       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz

  @@index([userId])
  @@index([aaguid])
  @@index([revokedAt])
  @@index([userId, revokedAt])
  @@map("fjn_webauthn_credentials")
}

// 21.6 WebAuthnChallenge (L-3: 注册/认证挑战临时存储)
model FjnWebAuthnChallenge {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String?   @db.Uuid // null for usernameless
  challenge String    @unique @db.VarChar(255) // base64url
  type      String    @db.VarChar(16) // registration | authentication
  sessionId String?   @db.VarChar(128) // 浏览器会话标识
  ipAddress String?   @db.VarChar(64)
  userAgent String?   @db.VarChar(512)
  usedAt    DateTime? @db.Timestamptz // null until consumed
  expiresAt DateTime  @db.Timestamptz // 5 minutes TTL
  createdAt DateTime  @default(now()) @db.Timestamptz

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("fjn_webauthn_challenges")
}

// ------------------------------------------------------------
// 22. 监控告警域 Monitoring Domain (M-1/M-2)
// ------------------------------------------------------------

// 22.1 SecurityAlert (M-2: 安全告警事件持久化)
model FjnSecurityAlert {
  id            String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  signature     String  @db.VarChar(64) // 去重签名（SHA-256 前 32 位）
  type          String  @db.VarChar(32) // replay_attack | abnormal_rotation | mfa_failure_rate | ...
  severity      String  @db.VarChar(16) // critical | high | medium | low | info
  severityLevel Int     @default(1) // 1-5 数值化
  userId        String? @db.Uuid
  resourceId    String? @db.VarChar(128) // sessionId / familyId / deviceId
  ipAddress     String? @db.VarChar(64)
  userAgent     String? @db.VarChar(512)
  message       String  @db.Text
  metadata      Json?   @db.JsonB
  traceId       String? @db.VarChar(64)
  source        String  @default("stock-exchange-dapp") @db.VarChar(64)
  environment   String  @default("development") @db.VarChar(32)

  // 投递状态
  deliveredToSiem Boolean   @default(false)
  siemDeliveredAt DateTime? @db.Timestamptz
  deliveryStatus  String    @default("pending") @db.VarChar(16) // pending | delivered | failed | partial

  // 审核状态
  acknowledged   Boolean   @default(false)
  acknowledgedBy String?   @db.Uuid
  acknowledgedAt DateTime? @db.Timestamptz
  resolution     String?   @db.Text
  resolvedAt     DateTime? @db.Timestamptz
  resolvedBy     String?   @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz

  @@index([type])
  @@index([severity])
  @@index([userId])
  @@index([createdAt])
  @@index([deliveryStatus])
  @@index([acknowledged])
  @@index([type, createdAt])
  @@index([severity, createdAt])
  @@index([userId, createdAt])
  @@map("fjn_security_alerts")
}

// 22.2 MfaFailureRecord (M-2: MFA 失败记录 - 用于失败率告警统计)
model FjnMfaFailureRecord {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String?  @db.Uuid
  failureType String   @db.VarChar(32) // invalid_code | expired_code | locked | backup_code_used | webauthn_failed
  ipAddress   String?  @db.VarChar(64)
  userAgent   String?  @db.VarChar(512)
  metadata    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @db.Timestamptz

  @@index([userId])
  @@index([failureType])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([failureType, createdAt])
  @@map("fjn_mfa_failure_records")
}

// 22.3 AlertConfig (M-2: 告警配置 - 阈值/通道/抑制规则)
model FjnAlertConfig {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  alertType       String   @unique @db.VarChar(32) // replay_attack | abnormal_rotation | mfa_failure_rate | ...
  enabled         Boolean  @default(true)
  minSeverity     String   @default("medium") @db.VarChar(16) // 低于此严重度不告警
  thresholdCount  Int      @default(1) // 触发阈值
  thresholdWindow Int      @default(60) // 触发窗口(秒)
  channels        String[] @db.Text // siem_webhook | database | console
  dedupWindowSec  Int      @default(300) // 去重窗口(秒)
  description     String?  @db.Text
  metadata        Json?    @db.JsonB
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @db.Timestamptz

  @@index([enabled])
  @@map("fjn_alert_configs")
}

// ============================================================
// 23. Solana 统一索引层 (Solana-first 架构)
// 文档：docs/工业级最终方案：Solana-first 统一生态架构.md §6
// 7 张核心 Solana 索引/对账表
// ============================================================

// 23.1 链上资产统一登记
model ChainAsset {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cluster      String    @db.VarChar(32) // mainnet-beta | testnet | devnet | localnet
  chainType    String    @default("solana") @db.VarChar(16)
  assetType    String    @db.VarChar(32) // native_sol | spl_token | token_2022 | nft_metaplex | nft_core
  mintAddress  String?   @db.VarChar(64) // NFT/Token 的 mint
  name         String?   @db.VarChar(128)
  symbol       String?   @db.VarChar(32)
  decimals     Int       @default(0)
  uri          String?   @db.VarChar(512) // NFT metadata URI
  ownerAddress String?   @db.VarChar(64)
  businessType String?   @db.VarChar(64) // fjn_nft | mall_nft | game_nft | sports_nft | club_nft | tFJ369 | ...
  businessId   String?   @db.Uuid
  userId       String?   @db.Uuid
  status       String    @default("active") @db.VarChar(32) // active | frozen | burned | transferred
  totalSupply  String?   @db.VarChar(64) // 字符串以支持大数
  metadata     Json?     @db.JsonB
  mintedAt     DateTime? @db.Timestamptz
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz

  @@unique([cluster, mintAddress])
  @@index([cluster])
  @@index([assetType])
  @@index([ownerAddress])
  @@index([businessType, businessId])
  @@index([userId])
  @@index([status])
  @@map("chain_assets")
}

// 23.2 链上交易统一登记
model ChainTransaction {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  signature    String    @db.VarChar(128)
  cluster      String    @db.VarChar(32)
  chainType    String    @default("solana") @db.VarChar(16)
  slot         BigInt? // Solana slot
  blockTime    DateTime? @db.Timestamptz
  fee          String?   @db.VarChar(32) // lamports
  feePayer     String?   @db.VarChar(64)
  txType       String    @db.VarChar(32) // transfer | mint | burn | nft_mint | nft_transfer | payment | release_claim | treasury_payout | ...
  status       String    @default("pending") @db.VarChar(32) // pending | submitted | confirmed | finalized | failed | expired | dropped
