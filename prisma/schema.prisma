// 手续费收入分配池：按周期把平台真实交易手续费收入的一部分计提出来，
// 按质押权重分给质押用户。totalWeight/poolAmount 在结算时一次性写入，不可变更。
model DefiFeeRevenuePool {
  id                  String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  periodStart         DateTime   @db.Timestamptz
  periodEnd           DateTime   @db.Timestamptz
  currency            String     @db.VarChar(20)
  totalFeeRevenue     Decimal    @default(0) @db.Decimal(36, 18)
  shareRatio          Decimal    @default(0) @db.Decimal(5, 4)
  poolAmount          Decimal    @default(0) @db.Decimal(36, 18)
  totalWeight         Decimal    @default(0) @db.Decimal(36, 18)
  distributedAmount   Decimal    @default(0) @db.Decimal(36, 18)
  status              String     @default("pending") @db.VarChar(20)
  createdAt           DateTime   @default(now()) @db.Timestamptz
  distributedAt       DateTime?  @db.Timestamptz

  distributions       DefiStakingRewardDistribution[]

  @@index([periodStart, periodEnd])
}

// 单笔质押在某个分配周期里实际分得的金额，weight = amount * 质押时长权重
model DefiStakingRewardDistribution {
  id                  String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  revenuePoolId       String     @db.Uuid
  stakingId           String     @db.Uuid
  userId              String     @db.Uuid
  weight              Decimal    @db.Decimal(36, 18)
  amount              Decimal    @db.Decimal(36, 18)
  currency            String     @db.VarChar(20)
  createdAt           DateTime   @default(now()) @db.Timestamptz

