model PerpContract {
  id                      String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  symbol                  String     @unique @db.VarChar(64)
  baseAsset               String     @db.VarChar(32)
  quoteAsset              String     @db.VarChar(32)
  marginAsset             String     @db.VarChar(32)
  contractType            String     @default("perpetual") @db.VarChar(32)
  maxLeverage             Int        @default(20)
  minOrderQty             Decimal    @default(0) @db.Decimal(36, 18)
  maxOrderQty             Decimal    @default(0) @db.Decimal(36, 18)
  maxPositionQty          Decimal    @default(0) @db.Decimal(36, 18)
  initialMarginRate       Decimal    @db.Decimal(18, 8)
  maintenanceMarginRate   Decimal    @db.Decimal(18, 8)
  makerFeeRate            Decimal    @db.Decimal(18, 8)
  takerFeeRate            Decimal    @db.Decimal(18, 8)
