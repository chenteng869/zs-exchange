  marginBalance           Decimal    @default(0) @db.Decimal(36, 18)
  unrealizedPnl           Decimal    @default(0) @db.Decimal(36, 18)
  realizedPnl             Decimal    @default(0) @db.Decimal(36, 18)
  fundingFeePaid          Decimal    @default(0) @db.Decimal(36, 18)
  fundingFeeReceived      Decimal    @default(0) @db.Decimal(36, 18)
