// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// core Schema - 用户/认证/权限/配置
// ============================================================

model CoreUser {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username          String    @unique @db.VarChar(50)
  email             String    @unique @db.VarChar(255)
  passwordHash      String    @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  countryCode       String    @default("CN") @db.Char(2)
  status            String    @default("active") @db.VarChar(20)
  kycLevel          Int       @default(0)
  referralCode      String?   @unique @db.VarChar(20)
  referredBy        String?   @db.Uuid
  userType          String    @default("retail") @db.VarChar(20)
  vipLevel          Int       @default(0)
  feeDiscount       Decimal   @default(0) @db.Decimal(5, 4)
  tradingEnabled    Boolean   @default(false)
  withdrawalEnabled Boolean   @default(false)
  depositEnabled    Boolean   @default(true)
  lastLoginAt       DateTime? @db.Timestamptz
  totpEnabled       Boolean   @default(false)
  totpSecret        String?   @db.VarChar(255)
  apiKeyCount       Int       @default(0)
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt         DateTime? @db.Timestamptz

  sessions      CoreSession[]
  apiKeys       CoreApiKey[]
  dids          CoreUserDid[]
  profiles      CoreUserProfile[]
  addresses     CoreUserAddress[]
  notifications CoreNotification[]
  userRoles     CoreUserRole[]
}

model CoreSession {
  id           String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String @db.Uuid
  token        String @unique @db.VarChar(512)
  refreshToken String @unique @db.VarChar(512)
  status       String @default("active") @db.VarChar(20)

  // P0-9 Refresh Token Rotation 字段
  refreshFamilyId String?   @db.Uuid // 同一登录族的 sessions 共享
  refreshUsed     Boolean   @default(false) // refresh token 是否已用过
  refreshUsedAt   DateTime? @db.Timestamptz // 首次被使用的时间
  rotatedFromId   String?   @db.Uuid // 本 session 由哪个 session 旋转而来
  rotationCount   Int       @default(0) // 旋转次数（用于检测异常）

  expiresAt DateTime @db.Timestamptz
  ipAddress String?  @db.VarChar(50)
  userAgent String?  @db.VarChar(512)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 注：DB 实际表名是 "CoreSession"（与初始迁移一致，无 @@map）

  @@index([userId])
  @@index([refreshFamilyId])
  @@index([refreshUsed])
  @@index([status])
  // K-6: 异常旋转检测 DB 降级路径（K-5 备用）
  @@index([userId, createdAt])
}

model CoreUserDid {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String    @db.Uuid
  did             String    @unique @db.VarChar(255)
  method          String    @db.VarChar(32)
  chainType       String    @default("solana") @db.VarChar(32)
  chainId         String    @default("devnet") @db.VarChar(64)
  publicKey       String    @db.VarChar(255)
  keyRef          String?   @db.VarChar(255)
  document        Json      @db.JsonB
  anchorStatus    String    @default("pending") @db.VarChar(32)
  anchorTxHash    String?   @db.VarChar(255)
  anchorBlockNo   BigInt?
  anchorTimestamp DateTime? @db.Timestamptz
  lastAnchoredAt  DateTime? @db.Timestamptz
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @db.Timestamptz

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([method, chainType, chainId])
  @@index([anchorStatus])
  @@map("core_user_dids")
}

model CoreApiKey {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String    @db.Uuid
  name        String    @db.VarChar(100)
  apiKey      String    @unique @db.VarChar(255)
  secretKey   String    @db.VarChar(255)
  permissions Json      @db.JsonB
  status      String    @default("active") @db.VarChar(20)
  lastUsedAt  DateTime? @db.Timestamptz
  expiresAt   DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamptz

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoreUserProfile {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @db.Uuid
  firstName String?  @db.VarChar(50)
  lastName  String?  @db.VarChar(50)
  avatar    String?  @db.VarChar(512)
  bio       String?  @db.Text
  timezone  String   @default("Asia/Shanghai") @db.VarChar(50)
  language  String   @default("zh") @db.VarChar(10)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoreUserAddress {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @db.Uuid
  address   String   @db.VarChar(512)
  tag       String   @db.VarChar(50)
  city      String?  @db.VarChar(100)
  province  String?  @db.VarChar(100)
  country   String   @db.VarChar(50)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoreNotification {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String    @db.Uuid
  type      String    @db.VarChar(50)
  title     String    @db.VarChar(200)
  content   String    @db.Text
  read      Boolean   @default(false)
  actionUrl String?   @db.VarChar(512)
  createdAt DateTime  @default(now()) @db.Timestamptz
  readAt    DateTime? @db.Timestamptz

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoreRole {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(500)
  permissions Json     @db.JsonB
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz

  userRoles CoreUserRole[]
}

model CoreUserRole {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz

  user CoreUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role CoreRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

model CoreSystemConfig {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       Json     @db.JsonB
  category    String   @db.VarChar(50)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz
}

model CoreAppVersion {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  platform    String   @db.VarChar(20)
  version     String   @db.VarChar(30)
  buildNumber String   @db.VarChar(20)
  forceUpdate Boolean  @default(false)
  changelog   String?  @db.Text
  downloadUrl String   @db.VarChar(512)
  createdAt   DateTime @default(now()) @db.Timestamptz
}

// ============================================================
// trade Schema - 交易/订单/成交/账本
// ============================================================

model TradePair {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  baseCurrency   String   @db.VarChar(20)
  quoteCurrency  String   @db.VarChar(20)
  symbol         String   @unique @db.VarChar(50)
  status         String   @default("active") @db.VarChar(20)
  basePrecision  Int      @default(8)
  quotePrecision Int      @default(8)
  minOrderAmount Decimal  @default(0) @db.Decimal(36, 18)
  minOrderValue  Decimal  @default(0) @db.Decimal(36, 18)
  makerFeeRate   Decimal  @default(0.001) @db.Decimal(5, 4)
  takerFeeRate   Decimal  @default(0.001) @db.Decimal(5, 4)
  priceTickSize  Decimal  @default(0.00000001) @db.Decimal(36, 18)
  amountTickSize Decimal  @default(0.00000001) @db.Decimal(36, 18)
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz

  orders     TradeOrder[]
  trades     TradeTrade[]
  orderBooks TradeOrderBook[]
}

model TradeOrder {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String    @db.Uuid
  pairId          String    @db.Uuid
  symbol          String    @db.VarChar(50)
  side            String    @db.VarChar(10)
  type            String    @db.VarChar(20)
  status          String    @default("pending") @db.VarChar(20)
  price           Decimal?  @db.Decimal(36, 18)
  amount          Decimal   @db.Decimal(36, 18)
  filledAmount    Decimal   @default(0) @db.Decimal(36, 18)
  remainingAmount Decimal   @default(0) @db.Decimal(36, 18)
  executedValue   Decimal   @default(0) @db.Decimal(36, 18)
  fee             Decimal   @default(0) @db.Decimal(36, 18)
  feeCurrency     String?   @db.VarChar(20)
  clientOrderId   String?   @db.VarChar(100)
  stopPrice       Decimal?  @db.Decimal(36, 18)
  timeInForce     String    @default("GTC") @db.VarChar(10)
  source          String    @default("web") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @db.Timestamptz
  closedAt        DateTime? @db.Timestamptz

  trades TradeTrade[]
  pair   TradePair    @relation(fields: [pairId], references: [id])
}

model TradeTrade {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId        String   @db.Uuid
  counterOrderId String   @db.Uuid
  pairId         String   @db.Uuid
  userId         String   @db.Uuid
  counterUserId  String   @db.Uuid
  symbol         String   @db.VarChar(50)
  side           String   @db.VarChar(10)
  price          Decimal  @db.Decimal(36, 18)
  amount         Decimal  @db.Decimal(36, 18)
  value          Decimal  @db.Decimal(36, 18)
  fee            Decimal  @default(0) @db.Decimal(36, 18)
  feeCurrency    String   @db.VarChar(20)
  liquidityType  String   @db.VarChar(10)
  createdAt      DateTime @default(now()) @db.Timestamptz

  order TradeOrder @relation(fields: [orderId], references: [id])
  pair  TradePair  @relation(fields: [pairId], references: [id])
}

model TradeBalance {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @db.Uuid
  currency  String   @db.VarChar(20)
  balance   Decimal  @default(0) @db.Decimal(36, 18)
  available Decimal  @default(0) @db.Decimal(36, 18)
  frozen    Decimal  @default(0) @db.Decimal(36, 18)
  locked    Decimal  @default(0) @db.Decimal(36, 18)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz
}

model TradeOrderBook {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pairId    String   @db.Uuid
  symbol    String   @db.VarChar(50)
  side      String   @db.VarChar(10)
  price     Decimal  @db.Decimal(36, 18)
  amount    Decimal  @db.Decimal(36, 18)
  count     Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz

  pair TradePair @relation(fields: [pairId], references: [id])
}

model TradePosition {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId            String    @db.Uuid
  symbol            String    @db.VarChar(50)
  positionSide      String    @db.VarChar(10)
  size              Decimal   @default(0) @db.Decimal(36, 18)
  entryPrice        Decimal   @default(0) @db.Decimal(36, 18)
  markPrice         Decimal   @default(0) @db.Decimal(36, 18)
  unrealizedPnl     Decimal   @default(0) @db.Decimal(36, 18)
  margin            Decimal   @default(0) @db.Decimal(36, 18)
  leverage          Int       @default(1)
  liquidationPrice  Decimal   @default(0) @db.Decimal(36, 18)
  maintenanceMargin Decimal   @default(0) @db.Decimal(36, 18)
  status            String    @default("open") @db.VarChar(20)
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @db.Timestamptz
  closedAt          DateTime? @db.Timestamptz
}

model TradeTransaction {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String   @db.Uuid
  type          String   @db.VarChar(20)
  currency      String   @db.VarChar(20)
  amount        Decimal  @db.Decimal(36, 18)
  balance       Decimal  @db.Decimal(36, 18)
  description   String?  @db.VarChar(500)
  referenceId   String?  @db.VarChar(100)
  referenceType String?  @db.VarChar(50)
  createdAt     DateTime @default(now()) @db.Timestamptz
}

model TradeFeeRecord {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @db.Uuid
  tradeId   String?  @db.Uuid
  orderId   String?  @db.Uuid
  currency  String   @db.VarChar(20)
  amount    Decimal  @default(0) @db.Decimal(36, 18)
  rate      Decimal  @default(0) @db.Decimal(5, 4)
  type      String   @db.VarChar(20)
  createdAt DateTime @default(now()) @db.Timestamptz
}

// ============================================================
// wallet Schema - 钱包/资产/充提/地址
// ============================================================

model WalletCurrency {
  id                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  symbol              String   @unique @db.VarChar(20)
  name                String   @db.VarChar(100)
  decimals            Int      @default(18)
  blockchain          String   @db.VarChar(50)
  contractAddress     String?  @db.VarChar(100)
  isFiat              Boolean  @default(false)
  isActive            Boolean  @default(true)
  depositEnabled      Boolean  @default(true)
  withdrawalEnabled   Boolean  @default(true)
  minDepositAmount    Decimal  @default(0) @db.Decimal(36, 18)
  minWithdrawalAmount Decimal  @default(0) @db.Decimal(36, 18)
  withdrawalFee       Decimal  @default(0) @db.Decimal(36, 18)
  withdrawalFeeRate   Decimal  @default(0) @db.Decimal(5, 4)
  confirmationCount   Int      @default(1)
  explorerUrl         String?  @db.VarChar(512)
  createdAt           DateTime @default(now()) @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @db.Timestamptz

  deposits    WalletDeposit[]
  withdrawals WalletWithdrawal[]
  addresses   WalletAddress[]
  hotCold     WalletHotCold[]
}

model WalletDeposit {
  id                    String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                String    @db.Uuid
  currencyId            String    @db.Uuid
  addressId             String    @db.Uuid
  txHash                String    @unique @db.VarChar(128)
  amount                Decimal   @db.Decimal(36, 18)
  fee                   Decimal   @default(0) @db.Decimal(36, 18)
  status                String    @default("pending") @db.VarChar(20)
  confirmations         Int       @default(0)
  requiredConfirmations Int       @default(1)
  blockNumber           String?   @db.VarChar(50)
  createdAt             DateTime  @default(now()) @db.Timestamptz
  updatedAt             DateTime  @default(now()) @updatedAt @db.Timestamptz
  confirmedAt           DateTime? @db.Timestamptz

  currency WalletCurrency @relation(fields: [currencyId], references: [id])
  address  WalletAddress  @relation(fields: [addressId], references: [id])
}

model WalletWithdrawal {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId             String    @db.Uuid
  currencyId         String    @db.Uuid
  amount             Decimal   @db.Decimal(36, 18)
  fee                Decimal   @default(0) @db.Decimal(36, 18)
  totalAmount        Decimal   @db.Decimal(36, 18)
  destinationAddress String    @db.VarChar(512)
  txHash             String?   @db.VarChar(128)
  status             String    @default("pending") @db.VarChar(20)
  memo               String?   @db.VarChar(200)
  blockNumber        String?   @db.VarChar(50)
  // 2026-07-11 新增（Alchemy Webhook 集成）
  minedAt            DateTime? @db.Timestamptz
  dropReason         String?   @db.VarChar(200)
  droppedAt          DateTime? @db.Timestamptz
  retryCount         Int       @default(0)
  lastRetryAt        DateTime? @db.Timestamptz
  createdAt          DateTime  @default(now()) @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @db.Timestamptz
  confirmedAt        DateTime? @db.Timestamptz

  currency WalletCurrency @relation(fields: [currencyId], references: [id])
}

model WalletAddress {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String   @db.Uuid
  currencyId String   @db.Uuid
  address    String   @unique @db.VarChar(512)
  tag        String?  @db.VarChar(100)
  status     String   @default("active") @db.VarChar(20)
  createdAt  DateTime @default(now()) @db.Timestamptz

  currency WalletCurrency  @relation(fields: [currencyId], references: [id])
  deposits WalletDeposit[]
}

model WalletHotCold {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type       String   @db.VarChar(20)
  currencyId String   @db.Uuid
  address    String   @db.VarChar(512)
  balance    Decimal  @default(0) @db.Decimal(36, 18)
  status     String   @default("active") @db.VarChar(20)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @db.Timestamptz

  currency WalletCurrency @relation(fields: [currencyId], references: [id])
}

model WalletInternalTransfer {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fromUserId  String    @db.Uuid
  toUserId    String    @db.Uuid
  currency    String    @db.VarChar(20)
  amount      Decimal   @db.Decimal(36, 18)
  status      String    @default("pending") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  completedAt DateTime? @db.Timestamptz
}

model WalletAddressBook {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String            @db.Uuid
  chainType       TransferChainType
  chainId         String            @db.VarChar(64)
  assetSymbol     String            @db.VarChar(64)
  contractAddress String?           @db.VarChar(255)
  address         String            @db.VarChar(255)
  label           String            @db.VarChar(100)
  isBlacklisted   Boolean           @default(false)
  createdAt       DateTime          @default(now()) @db.Timestamptz
  updatedAt       DateTime          @updatedAt @db.Timestamptz

  @@unique([userId, chainType, chainId, address])
  @@index([userId])
  @@index([chainType, chainId])
  @@index([address])
  @@map("wallet_address_books")
}

enum TransferChainType {
  evm
  tron
  solana
}

enum DepositAddressStatus {
  active
  disabled
  archived
}

enum DepositStatus {
  detected
  confirming
  confirmed
  credited
  failed
  ignored
  orphaned
}

enum WithdrawalStatus {
  created
  risk_checking
  waiting_approval
  approved
  signing
  signed
  broadcasting
  broadcasted
  confirming
  confirmed
  failed
  rejected
  canceled
}

enum ApprovalStatus {
  pending
  approved
  rejected
  expired
  canceled
}

enum HotWalletRole {
  hot
  warm
  cold
  fee
  sweep
}

enum HotWalletStatus {
  active
  frozen
  disabled
  maintenance
}

enum LedgerDirection {
  in
  out
}

enum LedgerBizType {
  deposit
  withdraw
  fee
  sweep
  rebalance
  manual_adjust
  correction
}

enum LockStatus {
  locked
  released
  consumed
  expired
}

enum SweepTaskStatus {
  pending
  signing
  signed
  broadcasting
  broadcasted
  confirmed
  failed
  canceled
}

enum ChainTxStatus {
  created
  signed
  broadcasted
  confirmed
  failed
  dropped
  replaced
}

enum ReconciliationStatus {
  pending
  matched
  mismatched
  resolved
  ignored
}

model WalletDepositAddress {
  id             String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String               @db.Uuid
  walletId       String?              @db.Uuid
  chainType      TransferChainType
  chainId        String               @db.VarChar(64)
  address        String               @db.VarChar(255)
  memo           String?              @db.VarChar(128)
  derivationPath String?              @db.VarChar(128)
  addressIndex   Int                  @default(0)
  addressType    String               @default("deposit") @db.VarChar(32)
  status         DepositAddressStatus @default(active)

  lastUsedAt DateTime? @db.Timestamptz
  createdAt  DateTime  @default(now()) @db.Timestamptz
  updatedAt  DateTime  @updatedAt @db.Timestamptz

  @@unique([chainType, chainId, address])
  @@index([userId])
  @@index([walletId])
  @@index([chainType, chainId])
  @@index([status])
  @@index([addressIndex])
  @@map("wallet_deposit_addresses")
}

model WalletChainCursor {
  id           String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  chainType    TransferChainType
  chainId      String            @db.VarChar(64)
  scannerName  String            @db.VarChar(64)
  currentBlock BigInt            @default(0) @db.BigInt
  safeBlock    BigInt            @default(0) @db.BigInt
  latestBlock  BigInt            @default(0) @db.BigInt
  status       String            @default("active") @db.VarChar(32)
  errorMessage String?           @db.VarChar(1024)
  updatedAt    DateTime          @updatedAt @db.Timestamptz
  createdAt    DateTime          @default(now()) @db.Timestamptz

  @@unique([chainType, chainId, scannerName])
  @@index([status])
  @@map("wallet_chain_cursors")
}

model WalletDepositRecord {
  id        String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  depositNo String @unique @db.VarChar(64)

  userId   String  @db.Uuid
  walletId String? @db.Uuid

  chainType             TransferChainType
  chainId               String            @db.VarChar(64)
  txHash                String            @db.VarChar(255)
  logIndex              Int?
  instructionIndex      Int?
  innerInstructionIndex Int?

  fromAddress String? @db.VarChar(255)
  toAddress   String  @db.VarChar(255)

