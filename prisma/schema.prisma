// ============================================================
// 27. Solana ICO 业务线（ADR-003 强制隔离双业务线之一）
// 文档：docs/02-技术规范/Solana上链与ICO发现机制讨论.md
// 数据库前缀：solana_ico_
// 与 FJN 369 主业务完全隔离（不共享 token / 不共享 order）
// ============================================================

// 27.1 ICO 代币发行信息
model IcoToken {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  symbol          String    @unique @db.VarChar(32) // 如 "LIQR"
  name            String    @db.VarChar(128)
  mintAddress     String?   @db.VarChar(64) // Solana SPL Token mint
  decimals        Int       @default(9)
  totalSupply     String    @db.VarChar(64) // 最小单位字符串
  saleSupply      String    @db.VarChar(64) // 本轮售卖量
  soldSupply      String    @default("0") @db.VarChar(64)
  pricePerToken   Decimal   @db.Decimal(20, 8) // USD per token
  raiseGoal       Decimal   @db.Decimal(20, 4) // USD
  raisedAmount    Decimal   @default(0) @db.Decimal(20, 4)
  acceptMints     String[]  @db.Text // 接受的支付 mint（USDC/USDT/SOL）
  chainCluster    String    @default("mainnet-beta") @db.VarChar(32)
  treasuryAddress String    @db.VarChar(64) // 收款国库
  // 释放规则
  tgePercent      Decimal   @default(0) @db.Decimal(5, 2) // TGE 解锁比例
  cliffDays       Int       @default(0)
  vestingDays     Int       @default(0)
  vestingType     String    @default("linear") @db.VarChar(32) // linear | cliff | step
  // 状态机：draft | presale | sale | finalized | cancelled | completed
  status          String    @default("draft") @db.VarChar(32)
  saleStartAt     DateTime? @db.Timestamptz
  saleEndAt       DateTime? @db.Timestamptz
  finalSnapshotAt DateTime? @db.Timestamptz
  description     String?   @db.Text
  metadataUri     String?   @db.VarChar(512)
  metadata        Json?     @db.JsonB
  createdBy       String?   @db.Uuid
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt       DateTime? @db.Timestamptz

  orders    IcoOrder[]
  schedules IcoVestingSchedule[]

  @@index([status])
  @@index([chainCluster])
  @@index([createdAt])
  @@map("solana_ico_tokens")
}

// 27.2 ICO 购买订单
model IcoOrder {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderNo        String    @unique @db.VarChar(64)
  tokenId        String    @db.Uuid
  userId         String    @db.Uuid
  payMint        String    @db.VarChar(64) // 用户支付的 mint（USDC/USDT/SOL）
  payAmount      String    @db.VarChar(64) // 最小单位
  usdValue       Decimal   @db.Decimal(20, 4)
  tokenAmount    String    @db.VarChar(64) // 实际获得 token 数量
  pricePerToken  Decimal   @db.Decimal(20, 8)
  // 状态机：created | paid | confirmed | vesting | claimed | failed | refunded | cancelled
  status         String    @default("created") @db.VarChar(32)
  payerWallet    String?   @db.VarChar(64)
  txSignature    String?   @db.VarChar(128)
  confirmedSlot  BigInt?
  confirmedAt    DateTime? @db.Timestamptz
  scheduleId     String?   @db.Uuid
  vestingStartAt DateTime? @db.Timestamptz
  vestingEndAt   DateTime? @db.Timestamptz
  kycVerified    Boolean   @default(false)
  regionCode     String?   @db.Char(2)
  note           String?   @db.Text
  metadata       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt      DateTime? @db.Timestamptz

  token    IcoToken            @relation(fields: [tokenId], references: [id])
  claims   IcoClaim[]
  schedule IcoVestingSchedule? @relation(fields: [scheduleId], references: [id])

  @@index([tokenId])
  @@index([userId])
  @@index([status])
  @@index([txSignature])
  @@index([createdAt])
  @@map("solana_ico_orders")
}

// 27.3 释放计划（每个 token / 每次私募 一份）
model IcoVestingSchedule {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tokenId         String    @db.Uuid
  scheduleNo      String    @unique @db.VarChar(64)
  name            String    @db.VarChar(128)
  // 状态机：draft | active | paused | completed | cancelled
  status          String    @default("draft") @db.VarChar(32)
  totalAmount     String    @db.VarChar(64) // 释放总量
  releasedAmount  String    @default("0") @db.VarChar(64)
  tgePercent      Decimal   @default(0) @db.Decimal(5, 2)
  cliffDays       Int       @default(0)
  vestingDays     Int       @default(0)
  vestingType     String    @default("linear") @db.VarChar(32)
  tgeAt           DateTime? @db.Timestamptz
  startAt         DateTime  @db.Timestamptz
  endAt           DateTime  @db.Timestamptz
  lastClaimAt     DateTime? @db.Timestamptz
  merkleRoot      String?   @db.VarChar(128) // 链下 Merkle 根（链上 Anchor 同步）
  authority       String    @db.VarChar(64) // PDA 拥有者
  // 链上 Anchor 绑定
  chainScheduleId String?   @db.VarChar(64) // fjn_release_program 中 PDA 地址
  chainTxSig      String?   @db.VarChar(128)
  metadata        Json?     @db.JsonB
  createdBy       String?   @db.Uuid
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt       DateTime? @db.Timestamptz

  token  IcoToken   @relation(fields: [tokenId], references: [id])
  orders IcoOrder[]

  @@index([tokenId])
  @@index([status])
  @@index([chainScheduleId])
  @@map("solana_ico_vesting_schedules")
}

// 27.4 用户释放领取记录
model IcoClaim {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  claimNo     String    @unique @db.VarChar(64)
  orderId     String    @db.Uuid
  userId      String    @db.Uuid
  scheduleId  String    @db.Uuid
  amount      String    @db.VarChar(64) // 本次领取数量
  claimableAt DateTime  @db.Timestamptz // 何时可领取
  // 状态机：pending | claimed | failed | expired
  status      String    @default("pending") @db.VarChar(32)
  txSignature String?   @db.VarChar(128)
  confirmedAt DateTime? @db.Timestamptz
  merkleProof String[]  @db.Text // Merkle 证明数组
  leafHash    String?   @db.VarChar(128)
  note        String?   @db.Text
  metadata    Json?     @db.JsonB
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamptz

  order IcoOrder @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([scheduleId])
  @@index([status])
  @@index([claimableAt])
  @@map("solana_ico_claims")
}

// 27.5 ICO 链上链下对账报告
model IcoReconciliationReport {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reportNo     String    @unique @db.VarChar(64)
  // type: token | order | schedule | treasury | all
  type         String    @db.VarChar(32)
  targetId     String?   @db.Uuid
  // status: pending | running | completed | failed | partial
  status       String    @default("pending") @db.VarChar(32)
  startedAt    DateTime  @default(now()) @db.Timestamptz
  completedAt  DateTime? @db.Timestamptz
  chainCluster String    @default("mainnet-beta") @db.VarChar(32)
  blockRange   Json?     @db.JsonB
  summary      Json?     @db.JsonB
  errorMessage String?   @db.Text
  triggeredBy  String?   @db.Uuid
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @db.Timestamptz

  discrepancies IcoReconciliationDiscrepancy[]

  @@index([type])
  @@index([status])
  @@index([chainCluster])
  @@index([createdAt])
  @@map("solana_ico_reconciliation_reports")
}

// 27.6 ICO 链上链下对账差异
model IcoReconciliationDiscrepancy {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reportId       String    @db.Uuid
  // type: order_mismatch | token_balance_mismatch | treasury_mismatch | missing_claim | extra_claim | amount_mismatch | status_mismatch
  type           String    @db.VarChar(64)
  // severity: low | medium | high | critical
  severity       String    @db.VarChar(16)
  resourceType   String    @db.VarChar(64)
  resourceId     String    @db.Uuid
  chainValue     String?   @db.Text
  offchainValue  String?   @db.Text
  diff           String?   @db.Text
  description    String    @db.Text
  autoFixed      Boolean   @default(false)
  fixedAt        DateTime? @db.Timestamptz
  resolutionNote String?   @db.Text
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz

  report IcoReconciliationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([type])
  @@index([severity])
  @@index([resourceType, resourceId])
  @@index([autoFixed])
  @@map("solana_ico_reconciliation_discrepancies")
}
