  file FileObject @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([principalType, principalId])
  @@map("file_permissions")
}

model FileAccessLog {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
