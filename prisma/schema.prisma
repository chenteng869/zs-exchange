// 18.6 ABAC 访问策略
model FjnAccessPolicy {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  policyCode  String    @unique @db.VarChar(128)
  policyName  String    @db.VarChar(128)
