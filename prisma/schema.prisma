model Web3MpcWallet {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  walletNo              String     @unique @db.VarChar(64)
  walletId              String     @db.Uuid
  orgId                 String?    @db.Uuid
  vaultId               String     @db.VarChar(128)
  provider              String     @db.VarChar(64)
  custodyType           String     @db.VarChar(32)
  chainType             String     @db.VarChar(32)
  chainId               String     @db.VarChar(64)
  address               String     @db.VarChar(255)
  publicKey             String?    @db.Text
  keyRef                String     @db.VarChar(255)
  status                String     @default("active") @db.VarChar(32)
  createdAt             DateTime   @default(now()) @db.Timestamptz
  updatedAt             DateTime   @default(now()) @updatedAt @db.Timestamptz

  wallet                Web3WalletProfile @relation(fields: [walletId], references: [id], onDelete: Cascade)
  signingRequests       Web3MpcSigningRequest[]

  @@index([walletId])
  @@index([provider])
  @@index([custodyType])
  @@index([chainType, chainId])
  @@index([status])
}

model Web3MpcSigningRequest {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  requestNo             String     @unique @db.VarChar(64)
  mpcWalletId           String     @db.Uuid
  walletId              String     @db.Uuid
  userId                String     @db.Uuid
  chainType             String     @db.VarChar(32)
  chainId               String     @db.VarChar(64)
  signType              String     @db.VarChar(32)
  payload               String     @db.Text
  payloadHash           String?    @db.VarChar(255)
  signature             String?    @db.Text
  status                String     @default("created") @db.VarChar(32)
  currentStage          String     @default("risk_checking") @db.VarChar(32)
  riskScore             Int        @default(0)
  riskLevel             String     @default("low") @db.VarChar(32)
  policyResult          Json?      @db.JsonB
  approvalWorkflowId    String?    @db.Uuid
  providerRequestId     String?    @db.VarChar(128)
  rejectReason          String?    @db.VarChar(512)
  expiresAt             DateTime?  @db.Timestamptz
  signedAt              DateTime?  @db.Timestamptz
  broadcastAt           DateTime?  @db.Timestamptz
  createdAt             DateTime   @default(now()) @db.Timestamptz
  updatedAt             DateTime   @default(now()) @updatedAt @db.Timestamptz

  mpcWallet             Web3MpcWallet @relation(fields: [mpcWalletId], references: [id], onDelete: Cascade)

  @@index([mpcWalletId])
  @@index([walletId])
  @@index([userId])
  @@index([status])
  @@index([currentStage])
  @@index([createdAt])
}

model Web3MpcPolicy {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  policyNo              String     @unique @db.VarChar(64)
  policyName            String     @db.VarChar(128)
  orgId                 String?    @db.Uuid
  vaultId               String?    @db.VarChar(128)
  policyType            String     @db.VarChar(32)
  description           String?    @db.Text
  rules                 Json?      @db.JsonB
  approvers             Json?      @db.JsonB
  threshold             Int        @default(1)
  priority              Int        @default(0)
  enabled               Boolean    @default(true)
  createdAt             DateTime   @default(now()) @db.Timestamptz
  updatedAt             DateTime   @default(now()) @updatedAt @db.Timestamptz

  @@index([orgId])
  @@index([vaultId])
  @@index([policyType])
  @@index([enabled])
}

model Web3ApprovalWorkflow {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workflowNo            String     @unique @db.VarChar(64)
  requestType           String     @db.VarChar(32)
  requestId             String     @db.VarChar(128)
  walletId              String?    @db.Uuid
  userId                String     @db.Uuid
  status                String     @default("pending") @db.VarChar(32)
  currentStep           Int        @default(1)
  totalSteps            Int        @default(1)
  requiredApprovals     Int        @default(1)
  receivedApprovals     Int        @default(0)
  approvers             Json?      @db.JsonB
  approvals             Json?      @db.JsonB
  rejectReason          String?    @db.VarChar(512)
  expiresAt             DateTime?  @db.Timestamptz
  completedAt           DateTime?  @db.Timestamptz
  createdAt             DateTime   @default(now()) @db.Timestamptz
  updatedAt             DateTime   @default(now()) @updatedAt @db.Timestamptz

  @@index([requestType, requestId])
  @@index([walletId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Web3ComplianceReport {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reportNo              String     @unique @db.VarChar(64)
  reportType            String     @db.VarChar(32)
  reportFormat          String     @default("pdf") @db.VarChar(16)
  userId                String?    @db.Uuid
  walletId              String?    @db.Uuid
  orgId                 String?    @db.Uuid
  periodStart           DateTime   @db.Timestamptz
  periodEnd             DateTime   @db.Timestamptz
  status                String     @default("generating") @db.VarChar(32)
  fileUrl               String?    @db.VarChar(512)
  fileSize              BigInt?    @db.BigInt
  generatedBy           String?    @db.Uuid
  generatedAt           DateTime?  @db.Timestamptz
  expiresAt             DateTime?  @db.Timestamptz
  createdAt             DateTime   @default(now()) @db.Timestamptz
  updatedAt             DateTime   @default(now()) @updatedAt @db.Timestamptz

  @@index([reportType])
  @@index([userId])
  @@index([walletId])
  @@index([status])
  @@index([createdAt])
}

model Web3EvidencePack {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  packNo                String     @unique @db.VarChar(64)
  caseId                String     @db.VarChar(64)
  caseType              String     @db.VarChar(32)
  userId                String?    @db.Uuid
  walletId              String?    @db.Uuid
  title                 String     @db.VarChar(255)
  description           String?    @db.Text
  items                 Json?      @db.JsonB
  fileUrl               String?    @db.VarChar(512)
  fileHash              String?    @db.VarChar(255)
  status                String     @default("draft") @db.VarChar(32)
  createdBy             String?    @db.Uuid
  createdAt             DateTime   @default(now()) @db.Timestamptz
  updatedAt             DateTime   @default(now()) @updatedAt @db.Timestamptz
  sealedAt              DateTime?  @db.Timestamptz

  @@index([caseId])
  @@index([caseType])
  @@index([userId])
  @@index([walletId])
  @@index([status])
}

model Web3WalletNotification {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  notificationNo        String     @unique @db.VarChar(64)
  userId                String     @db.Uuid
  walletId              String?    @db.Uuid
  type                  String     @db.VarChar(32)
  category              String     @db.VarChar(32)
  priority              String     @default("normal") @db.VarChar(32)
  title                 String     @db.VarChar(255)
  content               String     @db.Text
  metadata              Json?      @db.JsonB
  read                  Boolean    @default(false)
  readAt                DateTime?  @db.Timestamptz
  channel               String     @default("in_app") @db.VarChar(32)
  webhookUrl            String?    @db.VarChar(512)
  webhookStatus         String?    @db.VarChar(32)
  webhookRetryCount     Int        @default(0)
  createdAt             DateTime   @default(now()) @db.Timestamptz

  @@index([userId])
  @@index([walletId])
  @@index([type, category])
  @@index([read])
  @@index([createdAt])
}

model Web3WalletWebhook {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  webhookNo             String     @unique @db.VarChar(64)
  userId                String     @db.Uuid
  walletId              String?    @db.Uuid
  name                  String     @db.VarChar(128)
  url                   String     @db.VarChar(512)
  secret                String     @db.VarChar(255)
  events                Json?      @db.JsonB
  enabled               Boolean    @default(true)
  status                String     @default("active") @db.VarChar(32)
  lastTriggeredAt       DateTime?  @db.Timestamptz
  failureCount          Int        @default(0)
  createdAt             DateTime   @default(now()) @db.Timestamptz
  updatedAt             DateTime   @default(now()) @updatedAt @db.Timestamptz

  @@index([userId])
  @@index([walletId])
  @@index([enabled])
  @@index([status])
}

// Exchange/service API key storage (Binance, Alchemy, MoonPay, etc.)
model ExchangeApiKey {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  provider      String    @db.VarChar(100)
  name          String    @db.VarChar(100)
  apiKey        String    @db.VarChar(512)
  secretKey     String?   @db.VarChar(512)
  passphrase    String?   @db.VarChar(512)
  description   String?   @db.VarChar(500)
  status        String    @default("active") @db.VarChar(20)
  expiresAt     DateTime? @db.Timestamptz
  lastUsedAt    DateTime? @db.Timestamptz
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @db.Timestamptz

  @@index([provider])
  @@index([status])
  @@map("exchange_api_keys")
}

// ============================================================
// spot Schema - 现货交易/订单/成交/账本
// ============================================================

enum SpotMarketStatus {
  trading
  pending
  suspended
  delisted
}

enum SpotOrderSide {
  buy
  sell
}

enum SpotOrderType {
  limit
  market
  stop_limit
  stop_market
}

enum SpotOrderStatus {
  pending
  open
  partially_filled
  filled
  canceled
  expired
  failed
}

enum SpotOrderTimeInForce {
  GTC
  IOC
  FOK
  GTD
}

enum SpotTradeRole {
  maker
  taker
}

enum SpotAccountLedgerType {
  trade
  fee
  transfer_in
  transfer_out
  adjustment
}

model SpotMarket {
  id                BigInt           @id @default(autoincrement())
  marketSymbol      String           @unique @db.VarChar(32)
  baseAsset         String           @db.VarChar(32)
  quoteAsset        String           @db.VarChar(32)
  pricePrecision    Int              @default(2)
  quantityPrecision Int              @default(8)
  minQuantity       Decimal          @default(0) @db.Decimal(36, 18)
  minNotional       Decimal          @default(0) @db.Decimal(36, 18)
  maxQuantity       Decimal          @default(0) @db.Decimal(36, 18)
  maxNotional       Decimal          @default(0) @db.Decimal(36, 18)
  makerFeeRate      Decimal          @default(0.001) @db.Decimal(18, 8)
  takerFeeRate      Decimal          @default(0.001) @db.Decimal(18, 8)
  priceTickSize     Decimal          @default(0.00000001) @db.Decimal(36, 18)
  status            SpotMarketStatus @default(trading)
  createdAt         DateTime         @default(now()) @db.Timestamptz
  updatedAt         DateTime         @default(now()) @updatedAt @db.Timestamptz

  orders            SpotOrder[]
  trades            SpotTrade[]

  @@index([baseAsset, quoteAsset])
  @@index([status])
  @@map("spot_markets")
}

model SpotAccount {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String    @db.Uuid
  asset        String    @db.VarChar(32)
  balance      Decimal   @default(0) @db.Decimal(36, 18)
  available    Decimal   @default(0) @db.Decimal(36, 18)
  frozen       Decimal   @default(0) @db.Decimal(36, 18)
  status       String    @default("active") @db.VarChar(32)
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @db.Timestamptz

  orders       SpotOrder[]
  ledgers      SpotAccountLedger[]

  @@unique([userId, asset], map: "uk_spot_user_asset")
  @@index([userId])
  @@index([asset])
  @@index([status])
  @@map("spot_accounts")
}

model SpotAccountLedger {
  id             String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ledgerNo       String                @unique @db.VarChar(64)
  userId         String                @db.Uuid
  accountId      String                @db.Uuid
  asset          String                @db.VarChar(32)
  type           SpotAccountLedgerType
  direction      String                @db.VarChar(16)
  amount         Decimal               @db.Decimal(36, 18)
  balanceBefore  Decimal               @db.Decimal(36, 18)
  balanceAfter   Decimal               @db.Decimal(36, 18)
  referenceId    String?               @db.VarChar(100)
  referenceType  String?               @db.VarChar(50)
  remark         String?               @db.VarChar(500)
  createdAt      DateTime              @default(now()) @db.Timestamptz

  account        SpotAccount           @relation(fields: [accountId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([type])
  @@index([createdAt])
  @@map("spot_account_ledgers")
}

model SpotOrder {
  id                String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderNo           String               @unique @db.VarChar(64)
  userId            String               @db.Uuid
  accountId         String               @db.Uuid
  marketId          BigInt               @db.BigInt
  marketSymbol      String               @db.VarChar(32)
  side              SpotOrderSide
  orderType         SpotOrderType
  price             Decimal              @default(0) @db.Decimal(36, 18)
  quantity          Decimal              @db.Decimal(36, 18)
  filledQuantity    Decimal              @default(0) @db.Decimal(36, 18)
  remainingQuantity Decimal              @default(0) @db.Decimal(36, 18)
  executedValue     Decimal              @default(0) @db.Decimal(36, 18)
  fee               Decimal              @default(0) @db.Decimal(36, 18)
  feeCurrency       String?              @db.VarChar(32)
  timeInForce       SpotOrderTimeInForce @default(GTC)
  stopPrice         Decimal?             @db.Decimal(36, 18)
  status            SpotOrderStatus      @default(pending)
  clientOrderId     String?              @db.VarChar(100)
  source            String               @default("web") @db.VarChar(32)
  createdAt         DateTime             @default(now()) @db.Timestamptz
  updatedAt         DateTime             @default(now()) @updatedAt @db.Timestamptz
  canceledAt        DateTime?            @db.Timestamptz
  expiredAt         DateTime?            @db.Timestamptz

  account           SpotAccount @relation(fields: [accountId], references: [id])
  market            SpotMarket  @relation(fields: [marketId], references: [id])
  trades            SpotTrade[]

  @@index([orderNo])
  @@index([userId])
  @@index([accountId])
  @@index([marketId])
  @@index([marketSymbol])
  @@index([status])
  @@index([createdAt])
  @@map("spot_orders")
}

model SpotTrade {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tradeNo           String        @unique @db.VarChar(64)
  orderId           String        @db.Uuid
  counterOrderId    String        @db.Uuid
  userId            String        @db.Uuid
  counterUserId     String        @db.Uuid
  marketId          BigInt        @db.BigInt
  marketSymbol      String        @db.VarChar(32)
  side              SpotOrderSide
  price             Decimal       @db.Decimal(36, 18)
  quantity          Decimal       @db.Decimal(36, 18)
  value             Decimal       @db.Decimal(36, 18)
  fee               Decimal       @default(0) @db.Decimal(36, 18)
  feeCurrency       String        @db.VarChar(32)
  role              SpotTradeRole
  makerOrderNo      String?       @db.VarChar(64)
  takerOrderNo      String?       @db.VarChar(64)
  tradeTime         DateTime      @default(now()) @db.Timestamptz

  order             SpotOrder @relation(fields: [orderId], references: [id])
  market            SpotMarket @relation(fields: [marketId], references: [id])

  @@index([tradeNo])
  @@index([orderId])
  @@index([counterOrderId])
  @@index([userId])
  @@index([marketId])
  @@index([marketSymbol])
  @@index([tradeTime])
  @@map("spot_trades")
}
