  fileSize     BigInt
  checksum     String?   @db.VarChar(128)
  ownerUserId  String?   @db.Uuid
  businessType String?   @db.VarChar(64)
  businessId   String?   @db.Uuid
  sensitivity  String    @default("internal") @db.VarChar(20) // public | internal | confidential | restricted
  storageClass String    @default("standard") @db.VarChar(20)
  status       String    @default("pending_upload") @db.VarChar(20) // pending_upload | uploaded | archived | deleted
  uploadedAt   DateTime? @db.Timestamptz
  archivedAt   DateTime? @db.Timestamptz
