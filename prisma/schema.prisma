// 18.1 角色定义
model FjnRole {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  roleCode    String    @unique @db.VarChar(64) // super_admin | admin | operator | kyc_reviewer | finance | risk | ...
  roleName    String    @db.VarChar(128)
  description String?   @db.Text
  roleType    String    @default("admin") @db.VarChar(16) // admin | operator | user | system
  status      String    @default("active") @db.VarChar(16) // active | disabled | deprecated
  isSystem    Boolean   @default(false) // 系统内置角色，禁止删除
  parentId    String?   @db.Uuid // 父角色（用于继承）
  sort        Int       @default(0)
  metadata    Json?     @db.JsonB
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt   DateTime? @db.Timestamptz

  @@index([status])
  @@index([roleType])
  @@index([parentId])
  @@map("fjn_roles")
}

// 18.2 权限定义
model FjnPermission {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  permissionCode String    @unique @db.VarChar(128) // orders.read | kyc.approve | finance.settlement.approve | ...
  permissionName String    @db.VarChar(128)
  description    String?   @db.Text
  resource       String    @db.VarChar(64) // orders | kyc | finance | risk | ...
  action         String    @db.VarChar(32) // read | write | approve | reject | freeze | ...
  permissionType String    @default("api") @db.VarChar(16) // api | menu | button | data
  status         String    @default("active") @db.VarChar(16) // active | disabled | deprecated
  isSystem       Boolean   @default(false) // 系统内置权限，禁止删除
  parentId       String?   @db.Uuid // 父权限（用于树形）
  sort           Int       @default(0)
  metadata       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz
  deletedAt      DateTime? @db.Timestamptz

  @@index([status])
  @@index([resource])
  @@index([resource, action])
  @@index([permissionType])
  @@map("fjn_permissions")
}

// 18.3 角色-权限映射
model FjnRolePermission {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
