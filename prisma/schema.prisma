// 24. 事件总线 Outbox（事件驱动架构统一出口）
// 文档：docs/工业级最终方案：Solana-first 统一生态架构.md §4.5
//
// 所有 Service 写操作事务内统一追加 outboxEvent，
// 由 Outbox Worker 异步分发到 Notification / Audit / Reporting / Indexer
// ============================================================

// 24.1 Outbox 事件表
model OutboxEvent {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventType     String    @db.VarChar(128) // e.g. fjn.order.paid | game.asset.mint_confirmed
  aggregateType String?   @db.VarChar(64) // e.g. order | nft | game_account | leaderboard
  aggregateId   String?   @db.Uuid
  businessType  String?   @db.VarChar(64) // fjn | mall | game | sports | nft | solana
  businessId    String?   @db.Uuid
  userId        String?   @db.Uuid
  payload       Json      @db.JsonB
  status        String    @default("pending") @db.VarChar(16) // pending | dispatched | failed | dead
  retryCount    Int       @default(0)
  maxRetries    Int       @default(5)
  lastError     String?   @db.Text
  dispatchedAt  DateTime? @db.Timestamptz
  nextAttemptAt DateTime? @db.Timestamptz
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @db.Timestamptz

  @@index([eventType])
  @@index([status])
  @@index([businessType, businessId])
  @@index([aggregateType, aggregateId])
  @@index([userId])
  @@index([createdAt])
  @@index([status, nextAttemptAt])
  @@map("outbox_events")
}

