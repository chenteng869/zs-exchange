{
  "name": "stock-exchange-dapp",
  "version": "1.0.0",
  "description": "中萨数字科技交易所",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3200",
    "dev:host": "next dev -p 3200 -H 0.0.0.0",
    "build": "node scripts/generate-apk-info.js && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc -p tsconfig.check.json --noEmit",
    "type-check:p0": "tsc -p tsconfig.check.json --noEmit",
    "type-check:full": "tsc -p tsconfig.json --noEmit --pretty false",
    "type-check:perp": "tsc -p tsconfig.perp.json --noEmit --pretty false",
    "health:p0": "node scripts/health-p0-check.cjs",
    "health:routes": "node scripts/route-health-check.cjs",
    "kms:mock": "node scripts/mock-kms-server.cjs",
    "kms:mock:e2e": "tsx scripts/kms-mock-e2e.ts",
    "format": "prettier --write .",
    "test": "node scripts/run-all-tests.cjs",
    "test:p0": "vitest run -c vitest.p0.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "apk:info": "node scripts/generate-apk-info.js",
    "apk:sync": "node scripts/generate-apk-info.js && copy /Y app-release.apk public\\zs-exchange.apk",
    "cap:sync": "cap sync android ios",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@hookform/resolvers": "^3.3.3",
    "@noble/ed25519": "^3.1.0",
    "@noble/secp256k1": "^3.1.0",
    "@prisma/client": "^5.19.1",
    "@solana/spl-memo": "^0.2.5",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.15.5",
    "antd": "^5.12.0",
    "axios": "^1.6.3",
    "bs58": "^6.0.0",
    "cmdk": "^1.1.1",
    "countup.js": "^2.10.0",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "js-sha3": "^0.9.3",
    "lodash": "^4.17.21",
    "lucide-react": "^1.17.0",
    "next": "^14.1.0",
    "next-intl": "^4.13.0",
    "pg": "^8.22.0",
    "pptxgenjs": "^4.0.1",
    "prisma": "^5.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.49.2",
    "recharts": "^3.8.1",
    "viem": "^2.53.1",
    "wagmi": "^2.19.5",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/node": "20.10.5",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "main": "fix-test-import.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
