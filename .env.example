# ============================================================
# Stock Exchange DApp - 环境变量示例
# 复制为 .env.local 或 .env.production 后使用
# ============================================================

# ---------- 应用基础配置 ----------
NEXT_PUBLIC_APP_NAME=中萨数字科技交易所
NEXT_PUBLIC_APP_URL=http://localhost:3200
NEXT_PUBLIC_API_BASE_URL=http://localhost:3200/api/v1
NEXTAUTH_SECRET=your-super-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3200

# ---------- 数据库 ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_exchange?schema=public
DB_PASSWORD=postgres

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ---------- 区块链 ----------
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/your-key
PRIVATE_KEY=your-wallet-private-key

# ---------- 第三方服务 ----------
ALCHEMY_API_KEY=your-alchemy-key
MOONPAY_API_KEY=your-moonpay-key
OPENAI_API_KEY=your-openai-key

# ---------- 监控 ----------
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9464

# ---------- Grafana ----------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ---------- 风控 ----------
MAX_LEVERAGE=125
MAX_POSITIONS_PER_USER=20
DAILY_ORDER_LIMIT=10000

# ---------- 合约引擎 ----------
FUNDING_INTERVAL_HOURS=8
INSURANCE_FUND_INITIAL=1000000
MATCHING_ENGINE_THREADS=4
