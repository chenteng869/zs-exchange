# ============================================================
# Stock Exchange DApp - 环境变量示例
# 复制为 .env.local 或 .env.production 后使用
# ============================================================

# ---------- 应用基础配置 ----------
NEXT_PUBLIC_APP_NAME=中萨数字科技交易所
NEXT_PUBLIC_APP_URL=http://localhost:3200
NEXT_PUBLIC_API_BASE_URL=http://localhost:3200/api/v1
NEXTAUTH_SECRET=your-super-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3200

# ---------- 数据库 ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_exchange?schema=public
DB_PASSWORD=postgres

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ---------- 区块链 ----------
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/your-key
PRIVATE_KEY=your-wallet-private-key

# ---------- DID Solana 签名 ----------
# local | kms
DID_SOLANA_SIGNER_PROVIDER=local
# 主备 RPC，可逗号分隔多个端点
DID_SOLANA_RPC_ENDPOINTS=https://api.devnet.solana.com,https://rpc.ankr.com/solana_devnet
# local signer（仅开发环境）
DID_SOLANA_PRIVATE_KEY=
# kms signer（预生产/生产）
DID_SOLANA_KMS_ENDPOINT=
DID_SOLANA_KMS_AUTH_TOKEN=
DID_SOLANA_KMS_TIMEOUT_MS=8000

# ---------- KMS Mock (本地联调) ----------
KMS_MOCK_BASE_URL=http://127.0.0.1:8787
KMS_MOCK_TOKEN=dev-kms-token
KMS_MOCK_HOST=127.0.0.1
KMS_MOCK_PORT=8787

# ---------- 第三方服务 ----------
ALCHEMY_API_KEY=your-alchemy-key
ALCHEMY_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-key
ALCHEMY_BSC_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/your-alchemy-key
ALCHEMY_POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-alchemy-key
ALCHEMY_ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your-alchemy-key
ALCHEMY_OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/your-alchemy-key
ALCHEMY_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-alchemy-key
ALCHEMY_SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your-alchemy-key
ALCHEMY_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-key
# Copy from the Alchemy Webhook details page. Do not use ALCHEMY_API_KEY here.
ALCHEMY_WEBHOOK_SIGNING_KEY=your-alchemy-webhook-signing-key
MOONPAY_API_KEY=your-moonpay-key
# Copy from MoonPay Developers/Webhooks. Do not use MOONPAY_API_KEY here.
MOONPAY_WEBHOOK_SECRET=your-moonpay-webhook-secret
OPENAI_API_KEY=your-openai-key

# ---------- Wallet deposit custody ----------
# Production must use controlled custody/provider addresses, never deterministic fake addresses.
# JSON keys can be "CHAIN:CURRENCY", "CHAIN:*", "*:CURRENCY", or "*:*".
# Example: {"ETH:USDT":["0x1111111111111111111111111111111111111111"],"TRON:USDT":["TXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"]}
WALLET_DEPOSIT_ADDRESS_POOL_JSON=
# Optional single-chain polling endpoints. Use provider URLs from Alchemy/QuickNode/TronGrid.
WALLET_EVM_RPC_ENDPOINTS=
WALLET_EVM_RPC_CHAIN_NAME=
WALLET_TRON_RPC_ENDPOINTS=
TRONGRID_API_KEY=
WALLET_RPC_TIMEOUT_MS=10000
WALLET_DEPOSIT_READINESS_CURRENCY=USDT
WALLET_DEPOSIT_READINESS_CHAIN=ethereum
WALLET_DEPOSIT_READINESS_PROBE_RPC=true
WALLET_DEPOSIT_REQUIRE_MOONPAY=true
WALLET_DEPOSIT_SMOKE_BASE_URL=http://127.0.0.1:3200
# Development-only escape hatch. Leave unset in staging/production.
# WALLET_DEPOSIT_ADDRESS_MODE=deterministic-dev

# ---------- 监控 ----------
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9464

# ---------- Grafana ----------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ---------- 风控 ----------
MAX_LEVERAGE=125
MAX_POSITIONS_PER_USER=20
DAILY_ORDER_LIMIT=10000

# ---------- 合约引擎 ----------
FUNDING_INTERVAL_HOURS=8
INSURANCE_FUND_INITIAL=1000000
MATCHING_ENGINE_THREADS=4
