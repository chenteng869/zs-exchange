#!/usr/bin/env bash
# =============================================================
# Git post-commit hook: 自动同步 CodeGraph 索引
# =============================================================
# 安装: 复制到 .git/hooks/post-commit
#       chmod +x .git/hooks/post-commit
# 卸载: 删除 .git/hooks/post-commit
# 团队一致性: 可使用 husky / lefthook / pre-commit 框架统一管理
# =============================================================

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

log_info() { echo -e "${CYAN}[CodeGraph]${NC} $1"; }
log_success() { echo -e "${GREEN}[CodeGraph ✓]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[CodeGraph !]${NC} $1"; }
log_error() { echo -e "${RED}[CodeGraph ✗]${NC} $1"; }

# 切换到 Git 仓库根目录
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$REPO_ROOT" ]; then
  log_error "无法找到 Git 仓库根目录"
  exit 1
fi

cd "$REPO_ROOT"

# 检查 .codegraph 目录是否存在
if [ ! -d ".codegraph" ]; then
  log_info "未发现 .codegraph 目录，正在初始化..."
  if codegraph init . 2>/dev/null; then
    log_success "CodeGraph 初始化完成"
  else
    log_error "CodeGraph 初始化失败"
    log_warn "请确认 codegraph CLI 已安装: npm i -g codegraph"
    log_warn "或访问: https://github.com/modelcontextprotocol/codegraph"
    exit 0  # 不阻断 commit
  fi
  exit 0
fi

# 获取变更文件统计
CHANGED_COUNT=$(git diff --name-only HEAD~1 HEAD 2>/dev/null | wc -l)
ADDED_COUNT=$(git diff --name-only --diff-filter=A HEAD~1 HEAD 2>/dev/null | wc -l)
DELETED_COUNT=$(git diff --name-only --diff-filter=D HEAD~1 HEAD 2>/dev/null | wc -l)

log_info "检测到 $CHANGED_COUNT 个变更文件 (新增 $ADDED_COUNT, 删除 $DELETED_COUNT)"

# 增量同步
log_info "正在增量同步 CodeGraph 索引..."

if command -v codegraph >/dev/null 2>&1; then
  SYNC_OUTPUT=$(codegraph sync . 2>&1)
  SYNC_EXIT=$?
  
  if [ $SYNC_EXIT -eq 0 ]; then
    # 显示同步结果
    echo "$SYNC_OUTPUT" | grep -E "(Indexed|files|nodes|edges|Done)" | head -5 | while read -r line; do
      log_info "$line"
    done
    log_success "CodeGraph 同步完成"
  else
    log_error "CodeGraph 同步失败 (exit: $SYNC_EXIT)"
    echo "$SYNC_OUTPUT" | tail -10 | while read -r line; do
      log_error "  $line"
    done
    log_warn "提示: 手动运行 'codegraph index .' 重建完整索引"
    log_warn "本 commit 已成功，不影响后续操作"
  fi
else
  log_warn "未安装 codegraph CLI，跳过同步"
  log_warn "安装方法: npm install -g codegraph"
fi

exit 0
