{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "next-env.d.ts",
    "src/app/api/health/route.ts",
    "src/app/api/v1/auth/**/*.ts",
    "src/app/api/v1/docs/**/*.ts",
    "src/app/api/v1/market/**/*.ts",
    "src/app/api/v1/trade/**/*.ts",
    "src/app/api/v1/user/**/*.ts",
    "src/app/api/v1/wallet/**/*.ts",
    "src/lib/api/**/*.ts",
    "src/lib/http/**/*.ts",
    "src/lib/logger.ts",
    "src/lib/prisma.ts",
    "src/lib/trade/**/*.ts",
    "src/repositories/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/app/_disabled_pages",
    "src/modules",
    "src/repositories/index.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
